export PORT=8080
# Server uses the pooler URL (hostname contains -pooler) in production.
# Migrations use DATABASE_DIRECT_URL — must be a direct connection, not PgBouncer.
# For local dev both point to the same local Postgres.
export DATABASE_URL=postgres://localhost:5432/gather?sslmode=disable
export DATABASE_DIRECT_URL=postgres://localhost:5432/gather?sslmode=disable
export GATHER_HMAC_SECRET=replace-with-output-of-make-secrets-hmac
